{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mimicry",
  "version": "0.1.0",
  "identifier": "com.mimicry.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mimicry",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhEOTIyNTFEM0RCNTRBN0EKUldSNlNyVTlIU1dTalp0ZnQ0THFPbTlIZWx6c0tZSWFYdmVRRWZMdXpLOG9Hd2tkaGRUTmFqNmUK",
      "endpoints": [
        "https://github.com/51hhh/Mimicry/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
