    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/minimap": "^1.5.4",
    "@vue-flow/node-resizer": "^1.5.1",
    "lucide-vue-next": "^1.0.0",
    "monaco-editor": "^0.55.1",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.2.2",
    "vue": "^3.5.13",
    "vue-i18n": "^11.3.2",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@tauri-apps/cli": "^2",
    "@vitejs/plugin-vue": "^5.2.1",
